# ── Server ────────────────────────────────────────────────────────────────────
PORT=3001

# ── CORS ──────────────────────────────────────────────────────────────────────
# Lock this down in production, e.g. http://localhost:5173 for Vite dev
CORS_ORIGIN=*

# ── Database adapter ──────────────────────────────────────────────────────────
# "mock"     → uses seed.js (default, no setup needed)
# "firebase" → uses Firestore (requires serviceAccount.json)
DB_ADAPTER=firebase
